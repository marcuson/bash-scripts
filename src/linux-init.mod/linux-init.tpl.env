# Configurable variables

# -- General
# ---- User - the non root configured user
LI__USER=xxx
# ---- Installation type - server or desktop
LI__INSTALLATION_TYPE=server
# ---- Bitwarden integration
MBS__BW__URL=xxx
MBS__BW__CLIENT_ID=xxx
MBS__BW__CLIENT_SECRET=xxx
MBS__BW__MASTER_PASSWORD=xxx

# -- Step 0
# ---- APT - Add Docker repo
LI__ADD_DOCKER_APT_REPO__IS_ENABLED=y
# ---- APT - install packages
LI__APT_INSTALL_PACKAGES__IS_ENABLED=y
LI__APT_INSTALL_PACKAGES__PACKAGES="ca-certificates,curl,htop,git,unzip,docker-ce,docker-ce-cli,containerd.io,docker-buildx-plugin,docker-compose-plugin"
# ---- Services - docker
LI__SRV_DOCKER_ENABLER__IS_ENABLED=y
# ---- Git - basic config
LI__GIT_CONFIG__IS_ENABLED=y
LI__GIT_CONFIG__USERNAME="FirstName LastName"
LI__GIT_CONFIG__EMAIL="xxx@xxx.com"
# ---- Journal - limit size
LI__JOURNAL_LIMIT__IS_ENABLED=y
LI__JOURNAL_LIMIT__SYSTEM_MAX="1024M"
LI__JOURNAL_LIMIT__FILE_MAX="100M"
# ---- Nano - enable syntax highlighting
LI__NANO_SYNTAX_HIGHLIGHTING__IS_ENABLED=y
# ---- Network - enable routing
LI__NETWORK_ROUTING__IS_ENABLED=y
# ---- Network - enable src valid mark
LI__NETWORK_SRC_VALID_MARK__IS_ENABLED=y
# ---- SSH - prepare
# NOTE: No config for now
# ---- RAM - set swappiness
LI__RAM_SWAPPINESS__IS_ENABLED=y
LI__RAM_SWAPPINESS__VALUE="10"
# ---- User - add to groups
LI__USER_ADD_TO_GROUPS__IS_ENABLED=y
LI__USER_ADD_TO_GROUPS__GROUPS="docker,tty,uucp,lp"
# ---- User - sudo without password
LI__PASSWORDLESS_SUDO__IS_ENABLED=y
# ---- Install SOPS
LI__INSTALL_SOPS__IS_ENABLED=y
# ---- Install oh-my-posh
LI__INSTALL_OH_MY_POSH__IS_ENABLED=y
# ---- Komodo prep
LI__KOMODO_PREP__IS_ENABLED=y
LI__KOMODO_PREP__SOPS_KEY=xxx

# -- Step 1
# ---- Docker - login
LI__DOCKER_LOGIN__IS_ENABLED=y
LI__DOCKER_LOGIN__USERNAME="xxx"
# ---- Docker - custom bridge network
LI__DOCKER_NETWORK_CUSTOM_BRIDGE__IS_ENABLED=y
LI__DOCKER_NETWORK_CUSTOM_BRIDGE__NAME="dockernet_bridge"
# ---- Docker - start compose
LI__DOCKER_COMPOSE_START__IS_ENABLED=n
LI__DOCKER_COMPOSE_START__FILE_PATH="/absolute/path/to/docker-compose.yml"
# ---- Backup - restore
LI__BACKUP_RESTORE__IS_ENABLED=n
LI__BACKUP_RESTORE__FILE_PATH="/absolute/path/to/backup.tar.gz"
