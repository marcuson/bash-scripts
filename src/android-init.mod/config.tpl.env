# Configurable variables

# -- General
# ---- Bitwarden integration
MBS__BW__URL=xxx
MBS__BW__CLIENT_ID=xxx
MBS__BW__CLIENT_SECRET=xxx
MBS__BW__MASTER_PASSWORD=xxx

# -- Step 0
# ---- PKG - install packages
MBS__AI__PKG_INSTALL_PACKAGES__IS_ENABLED=y
MBS__AI__PKG_INSTALL_PACKAGES__PACKAGES="termux-api,termux-gui-package,openssh,git,ripgrep,npm"
# ---- Git - basic config
MBS__AI__GIT_CONFIG__IS_ENABLED=y
MBS__AI__GIT_CONFIG__USERNAME="FirstName LastName"
MBS__AI__GIT_CONFIG__EMAIL="xxx@xxx.com"
# ---- SSH - prepare
